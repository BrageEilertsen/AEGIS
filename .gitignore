# Python
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/

# Virtual environment (lives in repo dir on the cluster, never committed)
env/
.venv/

# Raw / downloaded data — public datasets, but never committed (see CLAUDE.md, spec §6)
data/raw/
data/processed/
data/**/*.csv
data/**/*.zip
*.parquet

# Run outputs, checkpoints, Slurm logs
outputs/
logs/*.out
logs/*.err
*.pt
*.ckpt

# Persistent spectral-feature cache contents (keep the dir, not the artifacts)
cache/features/*
!cache/features/.gitkeep

# Downloaded inference checkpoints (synced from cluster to Mac)
inference/model/*
!inference/model/.gitkeep

# Experiment tracking
wandb/
mlruns/

# Local Claude Code settings (machine-specific)
.claude/settings.local.json

# Operational / environment-specific docs kept LOCAL only — they contain cluster
# infrastructure details (SSH access tuple, internal hostnames) and must not be
# published to the public repo. Keep them on the cluster, never commit.
CLAUDE.md
docs/AEGIS_BUILD_SPEC.md

# Secrets — NEVER commit. Tokens/credentials live in env vars or the HF cache, not the repo.
.env
.env.*
*.token
hf_token*
**/secrets*
.huggingface/

# OS / editor
.DS_Store
*.swp
.idea/
.vscode/

# Node / Angular (frontend) build artifacts
frontend/node_modules/
frontend/.angular/
frontend/dist/

# Java / Maven (api) build artifacts
api/target/
