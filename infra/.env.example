# AEGIS local stack — copy to .env (`cp .env.example .env`). The defaults below match the
# standard repo layout, so for a normal `gcn_lismall` run you don't need to change anything.
#
# These are IN-CONTAINER paths. docker-compose mounts ../outputs -> /data/outputs and
# ../infra/seed -> /data/seed, so point these at the mounted locations.

# Trained checkpoint the inference service loads (change the run name if yours differs).
AEGIS_CHECKPOINT=/data/outputs/gcn_lismall/best.pt

# Seeded adversarial before/after artifact (committed in the repo under infra/seed/).
AEGIS_ADVERSARIAL_ARTIFACT=/data/seed/demo_adversarial_artifact.json
